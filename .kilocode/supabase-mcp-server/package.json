{
  "name": "@kilocode/supabase-mcp-server",
  "version": "1.0.0",
  "description": "Supabase MCP Server for managing database migrations, schema information, and common database operations",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist/"
  ],
  "sideEffects": false,
  "bin": {
    "supabase-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "prepare": "npm run build",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run"
  },
  "keywords": ["supabase", "mcp", "database", "migrations"],
  "author": "KiloCode",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.39.0",
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "pg": "^8.11.3",
    "zod": "^3.22.4",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.10.9",
    "@types/helmet": "^4.0.0",
    "@types/cors": "^2.8.17",
    "tsx": "^4.7.1",
    "typescript": "^5.3.2",
    "vitest": "^1.2.2",
    "rimraf": "^5.0.5"
  }
}