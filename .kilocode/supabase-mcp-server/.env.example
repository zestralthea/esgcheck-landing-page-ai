# Server config
PORT=3000
ADMIN_API_KEY=change-me-strong-random

# Supabase project
# Found project URL in src/integrations/supabase/client.ts
SUPABASE_URL=https://equtqvlukqloqphhmblj.supabase.co
# Service role key from Supabase > Project Settings > API (keep secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct database connection (Project Settings > Database > Connection string)
# Example format: postgresql://postgres:PASSWORD@db.equtqvlukqloqphhmblj.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.equtqvlukqloqphhmblj.supabase.co:5432/postgres

# Table access control (one of the two options)
# Option 1: allow all tables via PostgREST
ALLOW_ALL_TABLES=false
# Option 2: explicit allowlist (comma-separated)
TABLE_ALLOWLIST=organizations,organization_members,profiles,waitlist_entries,documents,jobs,esg_reports,esg_analyses,esg_analysis_exports,esg_frameworks,esg_guidelines,guideline_embeddings,activity_logs,document_access_logs,feature_flags,system_settings

