# Supabase Configuration
# IMPORTANT: Use staging/development Supabase project for non-production environments
# Production URL format: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OpenAI Configuration (for Edge Functions only)
OPENAI_API_KEY=your_openai_api_key

# PDFMonkey Configuration (for Edge Functions only)
PDFMONKEY_API_KEY=your_pdfmonkey_api_key
PDFMONKEY_TEMPLATE_ID=your_pdfmonkey_template_id

# LiteLLM Configuration (for Edge Functions only)
LITELLM_DROP_PARAMS=True
LITELLM_VERBOSE=False

# Environment Mode
# Automatically set by Vite: development, production, or test
# MODE is set via --mode flag or defaults to development/production based on command