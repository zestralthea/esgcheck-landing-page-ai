{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "destination": "/de/",
      "permanent": true
    },
    {
      "source": "/:locale(de|en|fr|it|rm)",
      "destination": "/:locale/",
      "permanent": true
    },
    {
      "source": "/:locale(de|en|fr|it|rm)/:flow(confirmation|thank-you)",
      "destination": "/:locale/:flow/",
      "permanent": true
    },
    {
      "source": "/subscribed",
      "destination": "/de/thank-you/",
      "permanent": true
    },
    {
      "source": "/thank-you",
      "destination": "/de/thank-you/",
      "permanent": true
    },
    {
      "source": "/confirmation",
      "destination": "/de/confirmation/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/:locale(de|en|fr|it|rm)/:flow(confirmation|thank-you)/",
      "headers": [
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}
